configuration {
    font: "JetBrainsMono Nerd Font 14";
    show-icons: false;
}

@import "~/.config/i3/themes/current/rofi.rasi"

window {
    transparency: "real";
    location: center;
    anchor: center;
    width: 450px;
    border: 1px;
    border-color: @primary;
    border-radius: 12px;
    background-color: @background;
    padding: 20px;
}

mainbox {
    background-color: transparent;
    orientation: vertical;
    children: [ "message", "listview" ];
    spacing: 20px;
}

message {
    background-color: transparent;
    padding: 10px;
}

textbox {
    background-color: transparent;
    text-color: @foreground;
    vertical-align: 0.5;
    horizontal-align: 0.5;
    markup: true;
}

listview {
    background-color: transparent;
    layout: horizontal;
    spacing: 30px;
    lines: 1;
    columns: 3;
    cycle: true;
    scrollbar: false;
    margin: 10px 45px 10px 45px;
}

element {
    background-color: @bg-alt;
    padding: 20px;
    border-radius: 100%;
    cursor: pointer;
    border: 1px;
    border-color: transparent;
}

element-text {
    background-color: transparent;
    text-color: @foreground;
    font: "JetBrainsMono Nerd Font 16";
    horizontal-align: 0.5;
    vertical-align: 0.5;
}

element selected {
    background-color: @primary;
    border-color: @primary;
}

element-text selected {
    text-color: #1E1E2E; 
}